{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python \".claude/Brain/hooks/guard-autoload.py\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python \".claude/Brain/hooks/session-stop.py\"",
            "async": true
          }
        ]
      }
    ]
  }
}
